#include<stdio.h>
#include<conio.h>

void main()
{
    int a[20], n, i, key, ch;
    int l, h, m, f = 0;

    clrscr();

    printf("Enter n: ");
    scanf("%d",&n);

    printf("Enter elements:\n");
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    printf("Enter key: ");
    scanf("%d",&key);

    printf("1.Linear 2.Binary: ");
    scanf("%d",&ch);

    if(ch==1)
    {
        for(i=0;i<n;i++)
        {
            if(a[i]==key)
            {
                printf("Found at position %d",i+1);
                f=1;
                break;
            }
        }
    }
    else
    {
        l=0;
        h=n-1;

        while(l<=h)
        {
            m=(l+h)/2;

            if(a[m]==key)
            {
                printf("Found at position %d",m+1);
                f=1;
                break;
            }

            if(key>a[m])
                l=m+1;
            else
                h=m-1;
        }
    }

    if(f==0)
        printf("Not Found");

    getch();
}