#include<stdio.h>
#include<conio.h>

void main()
{
    int h[10], i, key, pos;

    clrscr();

    for(i=0;i<10;i++)
        h[i]=-1;

    printf("Enter 5 keys:\n");

    for(i=0;i<5;i++)
    {
        scanf("%d",&key);

        pos=key%10;

        while(h[pos]!=-1)
            pos=(pos+1)%10;

        h[pos]=key;
    }

    printf("\nHash Table:\n");

    for(i=0;i<10;i++)
        printf("%d --> %d\n",i,h[i]);

    getch();
}

